                        {
                          "type": "text",
                          "id": "XdCWI",
                          "name": "Opening Section Title",
                          "fill": "$text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "A desktop article should feel deliberate before it feels expressive.",
                          "lineHeight": 1.08,
                          "fontFamily": "Geist",
                          "fontSize": 24,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "j3Uy2",
                          "name": "Opening Section Paragraph 1",
                          "fill": "$text-muted",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Long-form reading works when the page chooses one dominant task and protects it. On desktop, that means giving the article enough width to breathe while keeping utility visible but subordinate.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "PHMFK",
                          "name": "Opening Section Paragraph 2",
                          "fill": "$text-muted",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The quiet system here uses mostly white surfaces, restrained borders, and a compact metadata row. The typography carries the hierarchy, so the chrome can stay nearly invisible.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        }
                      ]
