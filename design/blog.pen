                          "name": "Rhythm Section Title",
                          "fill": "$text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The body can stay mostly unboxed if the spacing rhythm is consistent.",
                          "lineHeight": 1.08,
                          "fontFamily": "Geist",
                          "fontSize": 24,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "IdyWq",
                          "name": "Rhythm Section Paragraph 1",
                          "fill": "$text-muted",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Large sections are separated by whitespace, not by heavy cards. Only the quote, the checklist, and the continuation block gain a stronger surface because they interrupt the reading pace on purpose.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "KMx91",
                          "name": "Rhythm Section Paragraph 2",
                          "fill": "$text-muted",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "That balance makes the composition feel editorial instead of dashboard-like, while still staying inside a pragmatic shadcn-inspired component language.",
