                      "name": "Hierarchy Section",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 10,
                      "children": [
                        {
                          "type": "text",
                          "id": "dvOG3",
                          "name": "Hierarchy Section Eyebrow",
                          "fill": "$text-muted",
                          "content": "Hierarchy over chrome",
                          "fontFamily": "Geist Mono",
                          "fontSize": 11,
                          "fontWeight": "500"
                        },
                        {
                          "type": "text",
                          "id": "mV6WM",
                          "name": "Hierarchy Section Title",
                          "fill": "$text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "When metadata is sparse, it can sit near the title without competing with it.",
                          "lineHeight": 1.08,
                          "fontFamily": "Geist",
                          "fontSize": 24,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "mCkum",
                          "name": "Hierarchy Section Paragraph 1",
                          "fill": "$text-muted",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Each supporting element is compressed into a compact unit: date, read time, author, and system notes. Readers can scan them in a glance and return to the headline immediately.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Q2H5jO",
                          "name": "Hierarchy Section Paragraph 2",
                          "fill": "$text-muted",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The right rail then absorbs navigation, author context, and subscription prompts. That separation keeps the article column clean and makes the layout feel responsive even before it actually stacks on smaller screens.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        }
                      ]
                    },
