// Code highlight
.article-entry
  pre
    .highlight
      background transparent

    .gutter
      .line
        color $text-eyebrow

    .code
      .line
        color $text-secondary

  // Syntax highlighting tokens
  .highlight
    .comment
    .quote
      color $text-eyebrow
      font-style italic

    .keyword
    .selector-tag
    .addition
      color #635BFF
      font-weight 500

    .string
    .attr
    .value
      color #059669

    .number
    .literal
    .type
    .built_in
      color #D97706

    .title
    .section
    .name
      color #1A1A1A
      font-weight 600

    .variable
    .template-variable
      color #635BFF

    .params
      color $text-secondary

    .meta
      color $text-eyebrow

    .deletion
      color #EF4444
