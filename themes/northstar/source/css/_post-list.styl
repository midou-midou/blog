// Home page styles
.home-page
  responsive()
  padding-top $space-9

.home-layout
  display flex
  gap $gap
  align-items flex-start

  @media (max-width: $tablet)
    flex-direction column

.home-main
  flex 1
  max-width $article-width

  @media (max-width: $tablet)
    max-width 100%

// Hero section
.hero-section
  margin-bottom $space-9

.hero-card
  border-radius $radius-2xl
  background $surface-subtle
  border 1px solid $border
  padding $space-9

.hero-top-row
  display flex
  align-items center
  justify-content space-between
  margin-bottom $space-5

.hero-meta
  display flex
  align-items center
  gap $space-4

.hero-title
  font-family $font-display
  font-size $font-5xl
  font-weight 600
  line-height 1.08
  color $text
  margin-bottom $space-5

  a
    color inherit

    &:hover
      color $accent

.hero-deck
  font-family $font-body
  font-size $font-md
  color $text-muted
  line-height 1.55
  margin-bottom $space-7

// Articles section
.articles-section
  padding-bottom $space-9

.section-header
  display flex
  align-items center
  justify-content space-between
  margin-bottom $space-7

.section-eyebrow
  font-family $font-mono
  font-size $font-xs
  font-weight normal
  color $accent

.section-count
  font-family $font-mono
  font-size $font-sm
  color $text-muted

.articles-grid
  display flex
  flex-direction column
  gap $space-5

// Post card
.post-card
  card-base()
  padding $space-7
  display flex
  flex-direction column
  gap $space-4
  transition border-color 0.15s

  &:hover
    border-color $accent

.post-card-top
  display flex
  align-items center
  justify-content space-between

.post-card-title
  font-family $font-display
  font-size $font-lg
  font-weight 600
  color $text
  line-height 1.3

.post-card-excerpt
  font-family $font-body
  font-size $font-base
  color $text-muted
  line-height 1.5
  display -webkit-box
  -webkit-line-clamp 2
  -webkit-box-orient vertical
  overflow hidden

.post-card-footer
  margin-top auto

.read-link
  font-family $font-body
  font-size $font-base
  font-weight 500
  color $accent
