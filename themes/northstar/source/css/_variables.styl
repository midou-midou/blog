// Design tokens from .pen design file
// Color system with dark mode support

// Accent
$accent = #2D72D7
$accent-soft = rgba(99, 91, 255, 0.1)
$accent-foreground = #FFFFFF

// Surfaces (light mode)
$bg = #F7F8FA
$surface = #FFFFFF
$surface-subtle = #F7F8FA
$surface-strong = #1A1A1A

// Text
$text = #1A1A1A
$text-secondary = #374151
$text-muted = #6B7280
$text-eyebrow = #9CA3AF

// Borders
$border = #E5E7EB
$border-light = #F3F4F6

// Shadows
$shadow-color = rgba(0, 0, 0, 0.04)
$shadow = 0 1px 3px $shadow-color

// Typography
$font-display = 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif
$font-body = 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif
$font-mono = 'Geist Mono', 'SF Mono', 'Fira Code', monospace

// Font sizes
$font-xs = 11px
$font-sm = 12px
$font-base = 14px
$font-md = 15px
$font-lg = 17px
$font-xl = 18px
$font-2xl = 22px
$font-3xl = 24px
$font-4xl = 32px
$font-5xl = 34px

// Spacing
$space-1 = 4px
$space-2 = 6px
$space-3 = 8px
$space-4 = 10px
$space-5 = 12px
$space-6 = 14px
$space-7 = 16px
$space-8 = 18px
$space-9 = 20px
$space-10 = 22px
$space-12 = 24px

// Border radius
$radius-sm = 10px
$radius-md = 12px
$radius-lg = 16px
$radius-xl = 18px
$radius-2xl = 20px
$radius-pill = 9999px

// Layout
$max-width = 1120px
$article-width = 676px
$rail-width = 286px
$gap = 18px

// Breakpoints
$mobile = 479px
$tablet = 767px
$desktop = 768px
