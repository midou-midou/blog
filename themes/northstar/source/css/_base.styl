// Base reset and global styles
@import '_variables'
@import '_util/mixin'

*, *::before, *::after
  box-sizing border-box
  margin 0
  padding 0

html
  font-size 16px
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  scroll-behavior smooth

body
  font-family $font-body
  color $text
  background $bg
  line-height 1.5

a
  color inherit
  text-decoration none

img
  max-width 100%
  height auto

// Dark mode
html[data-theme="dark"]
  background $surface-strong
  color $accent-foreground

  body
    background $surface-strong

  .page-wrapper
    background $surface-strong

  .site-header
    background $surface-strong
    border-color rgba(255,255,255,0.08)

  .brand-title
    color #F3F4F6

  .brand-subtitle
    color $text-muted

  .nav-link
    color #9CA3AF

    &:hover
      color #F3F4F6

  .brand-mark
    background $accent
    color $accent-foreground

  .theme-toggle
    background rgba(255,255,255,0.06)

    .toggle-light
      color #9CA3AF

      &.active
        background transparent
        color #9CA3AF

    .toggle-dark
      &.active
        background $accent-foreground
        color $surface-strong

  .card
    background #1E1E1E
    border-color rgba(255,255,255,0.08)
    box-shadow none

  .hero-card
    background #1E1E1E
    border-color rgba(255,255,255,0.08)

  .article-title,
  .hero-title,
  .post-card-title,
  .archive-title,
  .next-title,
  .archive-year,
  .section-eyebrow
    color #F3F4F6

  .article-deck,
  .hero-deck,
  .post-card-excerpt,
  .author-bio,
  .meta-date,
  .read-time-pill,
  .archive-date,
  .meta-label,
  .footer-note
    color #9CA3AF

  .author-name
    color #F3F4F6

  .article-entry
    color #D1D5DB

    h1, h2, h3, h4, h5, h6
      color #F3F4F6

    a
      color $accent

    blockquote
      border-color rgba(255,255,255,0.1)
      color #D1D5DB

    code
      background rgba(255,255,255,0.06)
      color #E5E7EB

    pre
      background #111
      border-color rgba(255,255,255,0.08)

    table
      th
        background #1E1E1E
        color #F3F4F6
        border-color rgba(255,255,255,0.08)

      td
        border-color rgba(255,255,255,0.08)

  .chip-topic
    background rgba(255,255,255,0.06)
    color #D1D5DB
    border-color rgba(255,255,255,0.08)

  .btn-primary
    background $accent-foreground
    color $surface-strong

  .articles-section
    background $surface-strong

  .article-hero
    .meta-date,
    .read-time-pill
      color #9CA3AF

  .site-footer
    border-color rgba(255,255,255,0.08)

  .meta-value
    color #F3F4F6

  .stat-value
    color #F3F4F6

  .card-label
    color #9CA3AF

  .toc-card
    background #1E1E1E
    border-color rgba(255,255,255,0.08)

    .toc-label
      color #9CA3AF

    a
      color #9CA3AF

      &:hover
        color $accent

  .pagination
    a, span
      color #9CA3AF
      border-color rgba(255,255,255,0.08)

    .page-number:hover
      border-color $accent
      color $accent

    .current
      background $accent
      color $accent-foreground
      border-color $accent

  .archive-item
    background #1E1E1E
    border-color rgba(255,255,255,0.08)

    &:hover
      border-color $accent

  .read-link
    color $accent

  .highlight-card
    background #1E1E1E
    border-color rgba(255,255,255,0.08)

    .highlight-label
      color #9CA3AF

  .quote-card
    background #111

  .post-card
    &:hover
      border-color $accent

  .stat-item
    background #1E1E1E
    border-color rgba(255,255,255,0.08)

  .progress-ring-bg
    stroke rgba(255,255,255,0.08)

  .back-to-top-icon
    color #9CA3AF
