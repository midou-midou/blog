// Pagination
.pagination
  display flex
  align-items center
  justify-content center
  gap $space-3
  margin-top $space-9 * 2

  a, span
    font-family $font-body
    font-size $font-sm
    color $text-muted
    padding $space-2 $space-4
    border-radius $radius-md
    border 1px solid $border
    transition all 0.15s

  .page-number:hover
    border-color $accent
    color $accent

  .current
    background $accent
    color $accent-foreground
    border-color $accent

  .extend
    border none
    padding $space-2 $space-3

    &:hover
      border none
      color $accent

  .space
    border none
    color $text-muted
